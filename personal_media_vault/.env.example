IMAGEKIT_PUBLIC_KEY="public_xxxxxxxxxxxxxxxxxxxx"
IMAGEKIT_PRIVATE_KEY="private_xxxxxxxxxxxxxxxxxxxx"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_id"

# Admin credentials
ADMIN_USERNAME="ntnmedia"
# Generate hash: python -c "from passlib.context import CryptContext; print(CryptContext(schemes=['bcrypt']).hash('YOUR_PASSWORD'))"
ADMIN_PASSWORD_HASH="$2b$12$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# JWT — use a strong random string in production
SECRET_KEY="change-this-to-a-random-64-char-string"
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# DB — for Railway/Render use absolute path or keep default
DATABASE_URL="sqlite+aiosqlite:///./personal_media_vault.db"

# CORS — comma-separated list of allowed origins
# Production example: "https://your-app.vercel.app,https://yourdomain.com"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
