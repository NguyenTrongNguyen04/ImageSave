IMAGEKIT_PUBLIC_KEY="your_imagekit_public_key"
IMAGEKIT_PRIVATE_KEY="your_imagekit_private_key"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_imagekit_id"

# Admin credentials
ADMIN_USERNAME="ntnmedia"
# bcrypt hash for your admin password
ADMIN_PASSWORD_HASH="$2b$12$REPLACE_WITH_BCRYPT_HASH"

# JWT
SECRET_KEY="replace_with_long_random_string"
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# DB
DATABASE_URL="sqlite+aiosqlite:///./personal_media_vault.db"

# CORS (comma-separated). Example: "http://localhost:3000,http://127.0.0.1:3000"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
